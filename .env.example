# ============================================================
# Local HR RAG Chatbot — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# AI Provider selection
# Options: ollama | lmstudio | openai | claude | mistral
# ----------------------------------------------------------
AI_PROVIDER=ollama
MODEL_NAME=llama3.2

# ----------------------------------------------------------
# Embedding model (local, no API key required)
# ----------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----------------------------------------------------------
# Text splitting parameters
# ----------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ----------------------------------------------------------
# ChromaDB collection name
# ----------------------------------------------------------
CHROMA_COLLECTION_NAME=hr_documents

# ----------------------------------------------------------
# RAG retrieval parameters
# ----------------------------------------------------------
TOP_K_RESULTS=4
MIN_RELEVANCE_SCORE=0.3

# ----------------------------------------------------------
# Local provider endpoints (no API key needed)
# ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ----------------------------------------------------------
# Cloud provider API keys (only needed for cloud providers)
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
